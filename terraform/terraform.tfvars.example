# ── terraform.tfvars ──────────────────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in your details:
#   cp terraform.tfvars.example terraform.tfvars
#   terraform apply

aws_region           = "ap-south-1"
project_name         = "hudocafe"
environment          = "production"

# Your Route 53 domain name
domain_name          = "hudocafe.com"

# The Instance ID of your manually created EC2 instance in ap-south-1
existing_instance_id = "i-xxxxxxxxxxxxxxxxx"
