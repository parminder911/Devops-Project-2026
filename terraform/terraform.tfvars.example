# ── terraform.tfvars ──────────────────────────────────────────────────────────
# This is your actual variables file — it is listed in .gitignore (never committed).
# Copy this file: cp terraform.tfvars.example terraform.tfvars
# Then run: terraform apply -var-file=terraform.tfvars

aws_region         = "ap-south-1"
project_name       = "hudocafe"
environment        = "production"
instance_type      = "t3.medium"

# Your SSH key is at /root/.ssh/id_rsa.pub (generated in WSL as root)
public_key_path    = "/root/.ssh/id_rsa.pub"

domain_name        = "hudocafe.com"
app_subdomain      = "api"
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# IMPORTANT: Replace with YOUR actual IP to restrict SSH access
# Find your IP by running: curl ifconfig.me
allowed_ssh_cidr   = "0.0.0.0/0"
# After you know your IP, change to: "YOUR_IP/32"
