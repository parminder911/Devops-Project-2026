# ── Application Secrets ─────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git — it's listed in .gitignore

# PostgreSQL
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis (no auth for internal-only; add requirepass for extra hardening)
REDIS_HOST=redis
REDIS_PORT=6379

# Application
APP_ENV=production
APP_PORT=8000
